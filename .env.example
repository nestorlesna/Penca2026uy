# =============================================================================
# VARIABLES DE ENTORNO — PencaLes 2026
# =============================================================================
#
# DÓNDE VA CADA VARIABLE:
#
#   VITE_*  →  Se cargan en el NAVEGADOR (bundle público). Nunca poner secretos.
#              En local: crear un archivo .env en la raíz del proyecto.
#              En Vercel: Settings → Environment Variables.
#
#   Sin prefijo VITE_  →  Solo disponibles en las funciones serverless de Vercel
#              (carpeta api/). Nunca llegan al navegador.
#              En local: si usás `vercel dev`, se leen del .env también.
#              En Vercel: Settings → Environment Variables (marcar "Server").
#
# Copiar este archivo como .env y completar los valores reales.
# NUNCA subir el .env con valores reales al repositorio.
# =============================================================================


# -----------------------------------------------------------------------------
# SUPABASE — Frontend (public)
# Estas claves son de acceso público y van dentro del bundle del navegador.
# Se obtienen en: Supabase Dashboard → Settings → API
# -----------------------------------------------------------------------------

# URL del proyecto Supabase (ej: https://abcdefghij.supabase.co)
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Anon/public key — identifica el proyecto, no es un secreto real
# (las políticas RLS controlan el acceso real a los datos)
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Cloudflare Turnstile — CAPTCHA invisible en el formulario de registro
# Se obtiene en: dash.cloudflare.com → Turnstile → Sites → Add site
# La site key es pública (va en el HTML). El secret va solo en Cloudflare.
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key_here


# -----------------------------------------------------------------------------
# SUPABASE — Serverless (secret)
# La service role key tiene acceso total sin restricciones RLS.
# NUNCA exponerla en el frontend. Solo usarla en api/*.ts (Vercel serverless).
# Se obtiene en: Supabase Dashboard → Settings → API → service_role key
# Configurar en: Vercel → Settings → Environment Variables
# -----------------------------------------------------------------------------

# Mismo valor que VITE_SUPABASE_URL pero para el contexto serverless
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Service role key — acceso total a Supabase sin restricciones RLS
# Usada en: api/send-email.ts, api/football-data.ts, api/api-football.ts, api/sportsdb.ts
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here


# -----------------------------------------------------------------------------
# SMTP — Envío de correos (secret)
# Usado por: api/send-email.ts (función serverless de Vercel)
# Flujo: admin genera cola de correos desde /admin/correos →
#        presiona "Enviar" → llama a /api/send-email →
#        la función lee estas vars y envía vía SMTP.
# Configurar en: Vercel → Settings → Environment Variables
#
# Para Gmail:
#   - Habilitar autenticación en 2 pasos en la cuenta Google
#   - Crear una "Contraseña de aplicación" en: myaccount.google.com/apppasswords
#   - Usar esa contraseña de 16 caracteres como SMTP_PASS (no la contraseña real)
# -----------------------------------------------------------------------------

# Servidor SMTP (ej: smtp.gmail.com para Gmail, smtp.hostinger.com para Hostinger)
SMTP_HOST=smtp.gmail.com

# Puerto SMTP. 587 = TLS/STARTTLS (recomendado). 465 = SSL legacy. 25 = sin cifrado.
SMTP_PORT=587

# Usar SSL directo en el puerto (true solo si SMTP_PORT=465, false para 587)
SMTP_SECURE=false

# Dirección de email desde la que se envían los correos
SMTP_USER=tucuenta@gmail.com

# Contraseña del servidor SMTP.
# Para Gmail: usar "Contraseña de aplicación" (no la contraseña real de la cuenta)
SMTP_PASS=tu_app_password_de_google

# Nombre que aparece como remitente en los correos enviados
SMTP_FROM_NAME=PencaLes 2026


# -----------------------------------------------------------------------------
# APIs EXTERNAS DE FÚTBOL — Resultados Automáticos (secret)
# Usadas por: api/football-data.ts, api/api-football.ts, api/sportsdb.ts
# Estas funciones serverless actúan como proxy: el admin consulta desde
# /admin/resultauto → el navegador llama a /api/football-data?path=... →
# la función serverless agrega la key y llama a la API externa.
# Las keys NUNCA llegan al navegador.
# Configurar en: Vercel → Settings → Environment Variables
#
# IMPORTANTE: estas son solo para consulta informativa. La pantalla
# /admin/resultauto es de solo lectura y no modifica datos de la penca.
# -----------------------------------------------------------------------------

# football-data.org — API REST v4
# Registro gratuito en: https://www.football-data.org/client/register
# Key disponible en: https://www.football-data.org/client → "Auth Token"
# Plan gratuito: 10 req/min, acceso a competiciones principales incl. WC
# Usada en: api/football-data.ts → Header X-Auth-Token
FOOTBALL_DATA_API_KEY=your_football_data_api_key_here

# api-football.com (api-sports.io) — API REST v3
# Registro en: https://dashboard.api-football.com/register
# Key disponible en el dashboard una vez registrado
# Plan gratuito: 100 req/día, acceso a todas las ligas
# URL base: https://v3.football.api-sports.io (NO vía RapidAPI)
# Usada en: api/api-football.ts → Header x-apisports-key
API_FOOTBALL_KEY=your_api_football_key_here

# thesportsdb.com — API REST v1
# Plan gratuito: clave pública "3" (sin registro, datos limitados)
# Plan de pago (Patreon): clave numérica propia con más endpoints
# Registro/info en: https://www.thesportsdb.com/api.php
# La key va en la URL: /api/v1/json/{key}/endpoint.php
# Usada en: api/sportsdb.ts
SPORTSDB_API_KEY=3
